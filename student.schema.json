{
    "type": "object",
    "required": ["id", "last_name", "first_name", "section", "cours"],
    "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "last_name": { 
            "type": "string",
            "pattern": "^[a-zA-Z -]+$",
            "minLength": 2,
            "maxLength": 50
        },
        "first_name": {
            "type": "string",
            "pattern": "^[a-zA-Z -]+$",
            "minLength": 2,
            "maxLength": 50 
        },
        "section": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
                "id": { "type": "integer" },
                "name": { "type": "string" }
            }
        },
        "gender": { "enum": ["MALE", "FEMALE", "OTHER"] },
        "cours": { "type":"array", "items": { "enum": ["Geo", "Math", "Histoire"] }, "uniqueItems": true, "minItems": 1 }
    }
}